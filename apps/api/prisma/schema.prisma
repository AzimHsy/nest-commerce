// Prisma schema — single source of truth for the data model.
// The full commerce model (User, Product, Variant, Order, OrderItem,
// Voucher, WebhookEvent) lands in later units. Unit 1 only needs a
// working datasource + client so the /health endpoint can hit the db.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}
