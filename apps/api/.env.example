# API port
PORT=4000

# Postgres (docker-compose service on localhost:5432)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_commerce?schema=public"

# e2e test database (created by docker/postgres-init on first container start)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nest_commerce_test?schema=public"

# Auth — JWT access tokens (no refresh tokens in this project)
JWT_SECRET="change-me"
JWT_EXPIRES_IN="15m"

# Seed users (created by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@nest-commerce.local"
SEED_ADMIN_PASSWORD="admin1234"
SEED_STAFF_EMAIL="staff@nest-commerce.local"
SEED_STAFF_PASSWORD="staff1234"
